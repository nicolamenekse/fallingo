{
  "expo": {
    "name": "Fallingo",
    "slug": "fallingo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fallingo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Kahve fincanı ve el fotoğrafı çekmek için kamera gereklidir.",
        "NSPhotoLibraryUsageDescription": "Fotoğraf galerinizden fal resmi seçmek için gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D1A"
      },
      "package": "com.fallingo.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Fal resmi seçmek için galeri erişimi gereklidir.",
          "cameraPermission": "Fal resmi çekmek için kamera erişimi gereklidir."
        }
      ]
    ],
    "scheme": "fallingo",
    "experiments": {
      "typedRoutes": true
    }
  }
}
